{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "es2022",
    "module": "commonjs",
    "noImplicitAny": true,
    "strictNullChecks": false,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "seed.js", "search.js", "export.js", "coords.js", "slime.js",
    "markers.js", "presets.js", "favorites.js", "legend.js", "theme.js",
    "scripts/*.js"
  ]
}
