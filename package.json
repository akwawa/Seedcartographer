{
  "name": "seedcartographer",
  "version": "0.11.0",
  "description": "Minecraft Java seed explorer: find spots matching biome + adjacent biome + structure criteria, fully in the browser (cubiomes compiled to WebAssembly).",
  "private": true,
  "type": "module",
  "license": "CC-BY-NC-4.0",
  "scripts": {
    "test": "node --test",
    "serve": "python3 -m http.server 8000",
    "lint": "eslint .",
    "e2e": "playwright test",
    "coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info",
    "coverage:branches": "node --test --experimental-test-coverage --test-coverage-branches=100 --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-exclude='test/**' --test-coverage-exclude='scripts/**'",
    "lint:css": "stylelint styles.css fonts/fonts.css",
    "mutation": "stryker run",
    "typecheck": "tsc --noEmit",
    "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts npm --validate-https --validate-package-names --validate-integrity sha512"
  },
  "overrides": {
    "tmp": ">=0.2.6",
    "uuid": ">=11.1.1",
    "qs": ">=6.15.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "fast-check": "4.9.0",
    "globals": "^17.7.0",
    "lockfile-lint": "^5.0.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^7.0.2"
  }
}
