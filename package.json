{
  "name": "seedcartographer",
  "version": "1.0.0",
  "description": "Minecraft Java seed explorer: find spots matching biome + adjacent biome + structure criteria, fully in the browser (cubiomes compiled to WebAssembly).",
  "private": true,
  "license": "CC-BY-NC-4.0",
  "scripts": {
    "test": "node --test",
    "serve": "python3 -m http.server 8000",
    "lint": "eslint .",
    "e2e": "playwright test",
    "coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  }
}
