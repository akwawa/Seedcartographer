{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "command",
  "commandRunner": { "command": "node --test" },
  "mutate": [
    "coords.js", "export.js", "favorites.js", "legend.js", "maptools.js",
    "markers.js", "palette.js", "presets.js", "search.js", "searchhistory.js",
    "seed.js", "seedsearch.js", "sharestate.js", "slime.js", "theme.js",
    "tilecache.js", "tilegrid.js", "usermarkers.js", "userpresets.js"
  ],
  "ignoreStatic": true,
  "thresholds": { "high": 90, "low": 80, "break": 75 },
  "reporters": ["clear-text", "progress"],
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true
}
